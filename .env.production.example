# ============================================================================
# UniEvent Frontend — Variables d'environnement PRODUCTION (exemple)
# Copier en .env.production (ou configurer sur Vercel) et renseigner les valeurs.
# Les variables NEXT_PUBLIC_* sont exposées au navigateur (build-time).
# ============================================================================

# URL publique de l'API backend (Render)
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com

# Auth (si NextAuth est utilisé)
NEXTAUTH_SECRET=your-secret
NEXTAUTH_URL=https://your-app.vercel.app

# ─────────────────────────────────────────────────────────────────────────────
# UniEvent Backend — Environment Variables
# Copy this file to .env (gitignored) and fill in your values.
# Used by docker-compose.yml via env_file: .env
# Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Spring Profile ────────────────────────────────────────────────────────────
# Options: dev | staging | prod
SPRING_PROFILES_ACTIVE=dev

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/unievtdb
DB_USERNAME=unievt
DB_PASSWORD=unievt

# ── JWT ───────────────────────────────────────────────────────────────────────
# MUST be at least 32 characters (256 bits) for HS256.
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-256-bit-hex-string-before-deploying

# Access token lifetime in milliseconds (default: 900000 = 15 min)
JWT_ACCESS_TOKEN_EXPIRY_MS=900000

# Refresh token lifetime in days (default: 7)
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3001

# ── SMTP (not required for dev — MailHog is used instead) ────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=your-smtp-password

# ── Sentry (optional — error tracking) ───────────────────────────────────────
# Leave empty to disable.
SENTRY_DSN=

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
